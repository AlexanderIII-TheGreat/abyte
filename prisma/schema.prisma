datasource db {
  provider  = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Admin {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Author {
  id        String              @id @default(uuid())
  name      String
  avatar    String
  url       String
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  articles  Article[]
  translations AuthorTranslation[]
}

model AuthorTranslation {
  id           String   @id @default(uuid())
  authorId     String
  languageCode String   // "en" atau "id"
  role         String
  bio          String   @db.Text
  author       Author   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@unique([authorId, languageCode])
}

model Category {
  id           String                @id @default(uuid())
  slug         String                @unique
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  articles     Article[]
  translations CategoryTranslation[]
}

model CategoryTranslation {
  id           String   @id @default(uuid())
  categoryId   String
  languageCode String   // "en" atau "id"
  name         String
  description  String   @db.Text
  category     Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, languageCode])
}

model Article {
  id            String               @id @default(uuid())
  slug          String               @unique
  coverImage    String
  featured      Boolean              @default(false)
  datePublished DateTime             @default(now())
  dateModified  DateTime             @updatedAt
  authorId      String
  categoryId    String
  author        Author               @relation(fields: [authorId], references: [id])
  category      Category             @relation(fields: [categoryId], references: [id])
  translations  ArticleTranslation[]
  tags          ArticleTag[]
}

model ArticleTranslation {
  id            String   @id @default(uuid())
  articleId     String
  languageCode  String   // "en" atau "id"
  title         String
  description   String   @db.Text
  content       String   @db.Text
  coverImageAlt String
  readingTime   String
  article       Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, languageCode])
}

model Tag {
  id           String           @id @default(uuid())
  slug         String           @unique
  articles     ArticleTag[]
  translations TagTranslation[]
}

model TagTranslation {
  id           String   @id @default(uuid())
  tagId        String
  languageCode String   // "en" atau "id"
  name         String
  tag          Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([tagId, languageCode])
}

model ArticleTag {
  articleId String
  tagId     String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
}

model PageView {
  id         String   @id @default(uuid())
  url        String
  path       String
  referrer   String?  @db.Text
  visitorId  String
  userAgent  String?  @db.Text
  deviceType String?
  browser    String?
  ttfb       Int?
  fcp        Int?
  lcp        Int?
  dcl        Int?
  loadTime   Int?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([path, createdAt])
  @@index([visitorId, createdAt])
}
