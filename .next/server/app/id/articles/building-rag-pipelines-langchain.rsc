bidiffatir Al Majid"}],["$","meta","22",{"property":"article:tag","content":"RAG"}],["$","meta","23",{"property":"article:tag","content":"LangChain"}],["$","meta","24",{"property":"article:tag","content":"AI"}],["$","meta","25",{"property":"article:tag","content":"Vector Database"}],["$","meta","26",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","27",{"name":"twitter:title","content":"Membangun Pipeline RAG dengan LangChain dan Vector Database"}],["$","meta","28",{"name":"twitter:description","content":"Pelajari cara membangun Retrieval-Augmented Generation (RAG) pipeline untuk meningkatkan akurasi respons LLM dengan konteks dari data kamu sendiri."}],["$","meta","29",{"name":"twitter:image","content":"https://abyte.id/uploads/1780243069775-8cnpg5.png"}]]
