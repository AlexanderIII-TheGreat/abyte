":"Next.js"}],["$","meta","23",{"property":"article:tag","content":"React"}],["$","meta","24",{"property":"article:tag","content":"Server Components"}],["$","meta","25",{"property":"article:tag","content":"Performance"}],["$","meta","26",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","27",{"name":"twitter:title","content":"Menguasai React Server Components di Next.js 14"}],["$","meta","28",{"name":"twitter:description","content":"Pelajari cara memanfaatkan React Server Components di Next.js 14 untuk membangun aplikasi web yang lebih cepat dan efisien."}],["$","meta","29",{"name":"twitter:image","content":"https://abyte.id/uploads/1780240471315-mzhf5c.png"}]]
