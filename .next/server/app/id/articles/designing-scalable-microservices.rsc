operty":"article:tag","content":"Architecture"}],["$","meta","24",{"property":"article:tag","content":"Scalability"}],["$","meta","25",{"property":"article:tag","content":"System Design"}],["$","meta","26",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","27",{"name":"twitter:title","content":"Mendesain Arsitektur Microservices yang Skalabel"}],["$","meta","28",{"name":"twitter:description","content":"Panduan lengkap untuk mendesain arsitektur microservices yang dapat berkembang seiring pertumbuhan bisnis."}],["$","meta","29",{"name":"twitter:image","content":"https://abyte.id/uploads/1780242667777-s6nlaq.png"}]]
