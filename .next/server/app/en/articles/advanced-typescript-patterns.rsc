b:[["$","meta","0",{"name":"viewport","content":"width=device-width, initial-scale=1"}],["$","meta","1",{"charSet":"utf-8"}],["$","title","2",{"children":"Advanced TypeScript Patterns for Production Applications | abyte"}],["$","meta","3",{"name":"description","content":"Go beyond the basics of TypeScript with advanced patterns like discriminated unions, template literal types, conditional types, and practical utility types for production code."}],["$","link","4",{"rel":"author","href":"https://a2mdev.site"}],["$","meta","5",{"name":"author","content":"Abiyyu Abidiffatir Al Majid"}],["$","meta","6",{"name":"creator","content":"Abiyyu Abidiffatir Al Majid"}],["$","meta","7",{"name":"publisher","content":"abyte"}],["$","meta","8",{"name":"robots","content":"index, follow"}],["$","link","9",{"rel":"canonical","href":"https://abyte.id/en/articles/advanced-typescript-patterns"}],["$","meta","10",{"property":"og:title","content":"Advanced TypeScript Patterns for Production Applications"}],["$","meta","11",{"property":"og:description","content":"Go beyond the basics of TypeScript with advanced patterns like discriminated unions, template literal types, conditional types, and practical utility types for production code."}],["$","meta","12",{"property":"og:url","content":"https://abyte.id/en/articles/advanced-typescript-patterns"}],["$","meta","13",{"property":"og:site_name","content":"abyte"}],["$","meta","14",{"property":"og:image","content":"https://abyte.id/uploads/1780245097071-2ezo5d.webp"}],["$","meta","15",{"property":"og:image:width","content":"1200"}],["$","meta","16",{"property":"og:image:height","content":"630"}],["$","meta","17",{"property":"og:image:alt","content":"Advanced TypeScript Patterns for Production Applications"}],["$","meta","18",{"property":"og:type","content":"article"}],["$","meta","19",{"property":"article:published_time","content":"2024-01-20"}],["$","meta","20",{"property":"article:modified_time","content":"2026-05-31"}],["$","meta","21",{"prop